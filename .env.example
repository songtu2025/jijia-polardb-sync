APP_ENV=local
LOG_LEVEL=INFO
LOG_DIR=logs

JIJIA_BASE_URL=https://open.gerpgo.com
JIJIA_OPEN_GATEWAY_PREFIX=/api/open
JIJIA_APP_ID=your_app_id
JIJIA_APP_KEY=your_app_key
JIJIA_TOKEN_URL=/api_token

DB_HOST=your-polardb-host.mysql.polardb.rds.aliyuncs.com
DB_PORT=3306
DB_NAME=jijia_sync
DB_USER=your_db_user
DB_PASSWORD=your_db_password

API_CONFIG_PATH=config/api_config.example.yaml
